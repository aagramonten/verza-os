// Verza OS — Vera Chat MVP schema.
// Source of truth: docs/vera-chat-mvp-plan.md §2 + docs/vera-conversation-strategy.md §8.
// Conventions: uuid PKs, companyId on every tenant table + composite indexes,
// money in INT cents, append-only tables noted.

generator client {
  provider      = "prisma-client-js"
  // "native" for local dev; the Debian/OpenSSL 3.0 target is the production
  // container (node:20-slim = Debian Bookworm) so the correct query engine
  // is always bundled regardless of build-time OpenSSL detection.
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────────────

enum ServiceType {
  DESIGN_INSTALLATION
  LAWN
  IRRIGATION
  LIGHTING
  PLANTING
  CLEANUP
  MAINTENANCE
  OTHER
}

enum LeadStatus {
  DRAFT
  COLLECTING
  PENDING_CONFIRMATION
  READY_FOR_REVIEW
  ARCHIVED
}

// Owner-facing sales follow-up lifecycle. Independent of the intake pipeline
// (LeadStatus): a lead can be READY_FOR_REVIEW and still be NEW here until a
// human contacts the customer.
enum FollowUpStatus {
  NEW
  CONTACTED
  IN_FOLLOW_UP
  CLOSED
}

// Lifecycle of an owner-scheduled site visit. The owner (never Vera) confirms
// appointments against their own availability.
enum AppointmentStatus {
  PROPOSED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ChatSessionState {
  STARTED
  COLLECTING_CONTACT
  COLLECTING_PROJECT
  COLLECTING_MEDIA
  COLLECTING_MEASUREMENTS
  READY_FOR_CONFIRMATION
  CONFIRMED
  ABANDONED
}

enum ChatLanguage {
  ES
  EN
}

enum MessageRole {
  CUSTOMER
  VERA
  SYSTEM
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  CONDO
  OTHER
}

enum CustomerSource {
  CHAT
}

enum CustomerAuthPurpose {
  PORTAL_LOGIN
}

enum MediaKind {
  PHOTO
}

enum MediaUploader {
  CUSTOMER
  ADMIN
}

enum MeasurementSource {
  CUSTOMER
  VERA_EXTRACTED
  ADMIN
}

enum ConfirmationStatus {
  PENDING
  CONFIRMED
  CORRECTED
}

enum PricingUnit {
  SQFT
  FLAT
  PER_ZONE
}

enum ActorType {
  CUSTOMER
  VERA
  SYSTEM
  ADMIN
}

enum ConversionBand {
  VERY_HIGH
  HIGH
  MEDIUM
  LOW
  VERY_LOW
}

enum NextAction {
  SCHEDULE_SITE_VISIT
  TRUST_FIRST_FOLLOWUP
  SEND_PRELIMINARY_ESTIMATE
  REQUEST_MORE_PHOTOS
  LOW_PRIORITY_FOLLOWUP
}

enum UserRole {
  OWNER
  ADMIN
}

// ── Financials (projects, quotes, costs, marketing, payments) ────────

// Operational lifecycle of a delivered project. A project may originate
// from a won quote, a maintenance plan, or a manual internal workflow.
enum ProjectStatus {
  PLANNED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

// Official customer-facing quote. Versioned; approval requires a human
// actor (BUSINESS_RULES §Quote). Superseded rows are retained, never deleted.
enum QuoteStatus {
  DRAFT
  APPROVED
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  SUPERSEDED
}

// Cost categories for project profitability (owner requirement).
enum CostCategory {
  PLANTS
  SOIL
  MULCH
  DECORATIVE_ROCK
  IRRIGATION
  LIGHTING
  GRASS
  EQUIPMENT_RENTAL
  FUEL
  LABOR
  DISPOSAL
  MARKETING
  MISCELLANEOUS
}

// Advertising channels. Spend is tracked separately and optionally
// allocated to a project (BUSINESS_RULES §Marketing).
enum MarketingChannel {
  FACEBOOK_ADS
  INSTAGRAM_ADS
  GOOGLE_ADS
  TIKTOK_ADS
  REFERRAL
  OTHER
}

enum PaymentMethod {
  CASH
  ATH_MOVIL
  BANK_TRANSFER
  CARD
  CHECK
  OTHER
}

// Where a payment sits in the collection lifecycle of a project.
enum PaymentType {
  DEPOSIT
  PROGRESS
  FINAL
  REFUND
}

// ── Platform core ────────────────────────────────────────────────────

model Company {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]

  @@map("companies")
}

model User {
  id           String   @id @default(uuid())
  companyId    String
  email        String   @unique
  name         String
  role         UserRole @default(ADMIN)
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  // Human approver of official quotes (BUSINESS_RULES §Quote).
  approvedQuotes OfficialQuote[] @relation("QuoteApprover")
  refreshTokens  RefreshToken[]

  @@index([companyId, email])
  @@map("users")
}

// Opaque refresh tokens for the admin/owner console. The raw token is a
// 256-bit random string handed to the client once; only its SHA-256 hash is
// stored (same pattern as ChatSession.resumeTokenHash). Rotation is tracked
// by `familyId`: each refresh issues a new row and revokes the previous one;
// presenting an already-revoked token revokes the whole family (theft
// detection). Access tokens are stateless JWTs and are NOT stored here.
model RefreshToken {
  id             String    @id @default(uuid())
  companyId      String
  userId         String
  familyId       String
  tokenHash      String    @unique
  expiresAt      DateTime
  revokedAt      DateTime?
  replacedByHash String?
  userAgent      String?
  ipHash         String?
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([companyId, userId])
  @@index([familyId])
  @@map("refresh_tokens")
}

// Versioned weights for the deterministic scoring engines (strategy §6).
model ScoringConfig {
  id        String   @id @default(uuid())
  companyId String
  version   Int
  active    Boolean  @default(true)
  config    Json
  createdAt DateTime @default(now())

  @@unique([companyId, version])
  @@index([companyId, active])
  @@map("scoring_configs")
}

// ── CRM ──────────────────────────────────────────────────────────────

model Customer {
  id           String         @id @default(uuid())
  companyId    String
  name         String?
  phone        String? // E.164, normalized in application code
  email        String?
  municipality String?
  propertyType PropertyType?
  source       CustomerSource @default(CHAT)
  notes        String?        @db.Text
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  leads      Lead[]
  projects   Project[]
  authTokens CustomerAuthToken[]
  sessions   CustomerSession[]

  @@unique([companyId, phone])
  @@unique([companyId, id])
  @@index([companyId, email])
  @@index([companyId, createdAt])
  @@map("customers")
}

// Single-use passwordless login tokens for the customer portal. Raw tokens
// are delivered once through a notification port; only SHA-256 hashes persist.
model CustomerAuthToken {
  id         String              @id @default(uuid())
  companyId  String
  customerId String
  tokenHash  String              @unique
  purpose    CustomerAuthPurpose @default(PORTAL_LOGIN)
  expiresAt  DateTime
  usedAt     DateTime?
  ipHash     String?
  createdAt  DateTime            @default(now())

  customer Customer @relation(fields: [companyId, customerId], references: [companyId, id])

  @@index([companyId, customerId])
  @@index([companyId, expiresAt])
  @@map("customer_auth_tokens")
}

// Revocable opaque sessions for authenticated customers. The browser receives
// the raw token once; only its SHA-256 hash is stored.
model CustomerSession {
  id         String    @id @default(uuid())
  companyId  String
  customerId String
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  lastUsedAt DateTime
  ipHash     String?
  userAgent  String?
  createdAt  DateTime  @default(now())

  customer Customer @relation(fields: [companyId, customerId], references: [companyId, id])

  @@index([companyId, customerId])
  @@index([companyId, expiresAt])
  @@map("customer_sessions")
}

model Lead {
  id                  String          @id @default(uuid())
  companyId           String
  customerId          String?
  referenceNumber     String          @unique // VG-0042
  serviceType         ServiceType?
  status              LeadStatus      @default(DRAFT)
  description         String?         @db.Text
  requiresRemoval     Boolean?
  hasIrrigation       Boolean?
  budgetMinCents      Int?
  budgetMaxCents      Int?
  desiredDate         DateTime?
  preferredVisitTime  String?
  confirmedAt         DateTime?
  adminSummary        Json?
  // Owner-facing follow-up state; see FollowUpStatus.
  followUpStatus      FollowUpStatus  @default(NEW)
  // Working merge store for the Vera conversation (Day 3): validated field
  // values plus the set of customer-confirmed field names. Authoritative for
  // merge decisions and summary generation; typed columns above mirror it.
  collectedData       Json?
  // Deterministic scoring output (strategy §6/§8) — never exposed publicly.
  leadScore           Int?
  confidenceScore     Int?
  conversionBand      ConversionBand?
  suggestedNextAction NextAction?
  scoreBreakdown      Json?
  scoringVersion      Int?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  customer      Customer?            @relation(fields: [customerId], references: [id])
  sessions      ChatSession[]
  media         LeadMedia[]
  measurements  ProjectMeasurement[]
  confirmations LeadConfirmation[]
  estimates     EstimateRange[]
  projects      Project[]
  appointments  Appointment[]

  @@index([companyId, status])
  @@index([companyId, followUpStatus])
  @@index([companyId, createdAt])
  @@map("leads")
}

// ── Chat ─────────────────────────────────────────────────────────────

model ChatSession {
  id                   String           @id @default(uuid())
  companyId            String
  leadId               String?
  state                ChatSessionState @default(STARTED)
  language             ChatLanguage     @default(ES)
  resumeTokenHash      String           @unique // SHA-256 of the 256-bit resume token; raw token is never stored
  resumeTokenRevokedAt DateTime?
  lastActivityAt       DateTime         @default(now())
  expiresAt            DateTime
  ipHash               String
  userAgent            String?
  closedAt             DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  lead          Lead?              @relation(fields: [leadId], references: [id])
  messages      ChatMessage[]
  extractions   AiExtraction[]
  confirmations LeadConfirmation[]

  @@index([companyId, state])
  @@index([companyId, lastActivityAt])
  @@map("chat_sessions")
}

// Append-only.
model ChatMessage {
  id        String      @id @default(uuid())
  companyId String
  sessionId String
  role      MessageRole
  content   String      @db.Text
  metadata  Json?
  createdAt DateTime    @default(now())

  session     ChatSession    @relation(fields: [sessionId], references: [id])
  extractions AiExtraction[]

  @@index([companyId, sessionId, createdAt])
  @@map("chat_messages")
}

// ── Media & measurements ─────────────────────────────────────────────

model LeadMedia {
  id         String        @id @default(uuid())
  companyId  String
  leadId     String
  sessionId  String?
  kind       MediaKind     @default(PHOTO)
  storageKey String
  thumbKey   String?
  mime       String
  sizeBytes  Int
  width      Int?
  height     Int?
  uploadedBy MediaUploader @default(CUSTOMER)
  createdAt  DateTime      @default(now())

  lead Lead @relation(fields: [leadId], references: [id])

  @@index([companyId, leadId])
  @@map("lead_media")
}

model ProjectMeasurement {
  id        String            @id @default(uuid())
  companyId String
  leadId    String
  label     String
  lengthFt  Decimal           @db.Decimal(7, 2)
  widthFt   Decimal           @db.Decimal(7, 2)
  areaSqFt  Decimal           @db.Decimal(10, 2) // computed in application code, never by the AI
  source    MeasurementSource @default(CUSTOMER)
  notes     String?           @db.Text
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  lead Lead @relation(fields: [leadId], references: [id])

  @@index([companyId, leadId])
  @@map("project_measurements")
}

// Immutable snapshot of exactly what the customer confirmed.
model LeadConfirmation {
  id             String             @id @default(uuid())
  companyId      String
  leadId         String
  sessionId      String
  snapshot       Json
  status         ConfirmationStatus @default(PENDING)
  confirmedAt    DateTime?
  correctionNote String?            @db.Text
  createdAt      DateTime           @default(now())

  lead    Lead        @relation(fields: [leadId], references: [id])
  session ChatSession @relation(fields: [sessionId], references: [id])

  @@index([companyId, leadId])
  @@map("lead_confirmations")
}

// ── AI audit trail (append-only) ─────────────────────────────────────

model AiExtraction {
  id              String   @id @default(uuid())
  companyId       String
  sessionId       String
  messageId       String
  model           String
  promptVersion   String
  rawOutput       Json
  validatedOutput Json?
  valid           Boolean
  errors          Json?
  appliedFields   Json?
  latencyMs       Int
  tokensIn        Int?
  tokensOut       Int?
  createdAt       DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id])
  message ChatMessage @relation(fields: [messageId], references: [id])

  @@index([companyId, sessionId, createdAt])
  @@map("ai_extractions")
}

// ── Pricing (deterministic engine inputs/outputs) ────────────────────

model PricingRule {
  id              String      @id @default(uuid())
  companyId       String
  serviceType     ServiceType
  unit            PricingUnit
  minRateCents    Int
  maxRateCents    Int
  minimumJobCents Int
  factors         Json?
  version         Int
  active          Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  estimates EstimateRange[]

  @@unique([companyId, serviceType, version])
  @@index([companyId, serviceType, active])
  @@map("pricing_rules")
}

// Append-only: recompute = new row.
model EstimateRange {
  id              String   @id @default(uuid())
  companyId       String
  leadId          String
  pricingRuleId   String
  ruleVersion     Int
  inputs          Json
  lowCents        Int
  highCents       Int
  disclaimerShown Boolean  @default(true)
  createdAt       DateTime @default(now())

  lead        Lead        @relation(fields: [leadId], references: [id])
  pricingRule PricingRule @relation(fields: [pricingRuleId], references: [id])

  @@index([companyId, leadId, createdAt])
  @@map("estimate_ranges")
}

// ── Audit (append-only; no update/delete path exists in the API) ─────

model AuditLog {
  id        String    @id @default(uuid())
  companyId String
  actorType ActorType
  actorId   String?
  action    String
  entity    String
  entityId  String
  data      Json?
  createdAt DateTime  @default(now())

  @@index([companyId, entity, entityId])
  @@index([companyId, createdAt])
  @@map("audit_logs")
}

// ── Financials ───────────────────────────────────────────────────────
//
// The financial source of truth for a company. Money is always integer
// cents with an explicit currency (AGENTS.md §Money). Revenue is layered:
//   Quoted   → OfficialQuote.totalCents (versioned, human-approved)
//   Contract → Project.contractAmountCents (expected revenue)
//   Collected → sum(Payment.amountCents)
//   Outstanding → contract − collected
// Profit and margins are NOT stored; they are recomputed deterministically
// from these rows by the analytics layer. The model is intentionally
// additive so future invoicing/accounting modules can reference it
// (e.g. Payment.invoiceId) without breaking changes.

// A delivered piece of work. Owns costs, quotes, payments, and allocated
// marketing spend. May originate from a won lead or be created manually.
model Project {
  id                  String        @id @default(uuid())
  companyId           String
  leadId              String?
  customerId          String?
  referenceNumber     String        @unique // VGP-0001
  title               String?
  serviceType         ServiceType?
  status              ProjectStatus @default(PLANNED)
  scope               String?       @db.Text
  notes               String?       @db.Text
  currency            String        @default("USD")
  // Expected revenue. Populated from an accepted quote when available,
  // but the owner may always enter or override it manually.
  contractAmountCents Int?
  contractSignedAt    DateTime?
  wonAt               DateTime?
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  lead            Lead?            @relation(fields: [leadId], references: [id])
  customer        Customer?        @relation(fields: [customerId], references: [id])
  quotes          OfficialQuote[]
  costs           ProjectCost[]
  payments        Payment[]
  marketingSpends MarketingSpend[]

  @@index([companyId, status])
  @@index([companyId, createdAt])
  @@index([companyId, serviceType])
  @@index([companyId, leadId])
  @@map("projects")
}

// Official customer-facing offer. Versioned and append-only in spirit:
// recompute/renegotiate = new version; prior versions are SUPERSEDED,
// never mutated destructively. Approval requires a human actor.
model OfficialQuote {
  id               String      @id @default(uuid())
  companyId        String
  projectId        String
  version          Int
  status           QuoteStatus @default(DRAFT)
  currency         String      @default("USD")
  lineItems        Json?
  subtotalCents    Int
  taxCents         Int         @default(0)
  totalCents       Int
  validUntil       DateTime?
  approvedByUserId String?
  approvedAt       DateTime?
  sentAt           DateTime?
  acceptedAt       DateTime?
  notes            String?     @db.Text
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  project    Project @relation(fields: [projectId], references: [id])
  approvedBy User?   @relation("QuoteApprover", fields: [approvedByUserId], references: [id])

  @@unique([projectId, version])
  @@index([companyId, projectId])
  @@index([companyId, status])
  @@map("official_quotes")
}

// A single project expense. quantity × unitCostCents is mirrored into
// totalCents at write time so aggregates never depend on float math.
model ProjectCost {
  id            String       @id @default(uuid())
  companyId     String
  projectId     String
  category      CostCategory
  description   String
  vendor        String?
  quantity      Decimal      @default(1) @db.Decimal(12, 3)
  unitCostCents Int
  totalCents    Int
  currency      String       @default("USD")
  purchaseDate  DateTime
  receiptKey    String? // private storage key; short-lived URLs on read
  notes         String?      @db.Text
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id])

  @@index([companyId, projectId])
  @@index([companyId, category])
  @@index([companyId, purchaseDate])
  @@map("project_costs")
}

// Advertising spend. Tracked at the channel level and optionally
// allocated to a specific project for per-project profitability.
model MarketingSpend {
  id          String           @id @default(uuid())
  companyId   String
  channel     MarketingChannel
  description String?
  amountCents Int
  currency    String           @default("USD")
  spentAt     DateTime
  projectId   String? // optional allocation
  campaignRef String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  project Project? @relation(fields: [projectId], references: [id])

  @@index([companyId, spentAt])
  @@index([companyId, projectId])
  @@index([companyId, channel])
  @@map("marketing_spends")
}

// A payment received against a project. Sum drives Collected Revenue and
// cash-flow reporting. Designed so a future Invoice model can attach via
// an added invoiceId column without a breaking change.
model Payment {
  id          String        @id @default(uuid())
  companyId   String
  projectId   String
  amountCents Int
  currency    String        @default("USD")
  method      PaymentMethod
  type        PaymentType   @default(PROGRESS)
  reference   String?
  receivedAt  DateTime
  notes       String?       @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  project Project @relation(fields: [projectId], references: [id])

  @@index([companyId, projectId])
  @@index([companyId, receivedAt])
  @@map("payments")
}

// ── Scheduling (owner agenda, availability, site visits) ─────────────

// A scheduled site visit for a lead. scheduledAt is a UTC instant; the owner
// works in Puerto Rico local time (fixed UTC-4, no DST — see financials period).
model Appointment {
  id           String            @id @default(uuid())
  companyId    String
  leadId       String
  customerId   String?
  scheduledAt  DateTime
  durationMin  Int               @default(60)
  status       AppointmentStatus @default(CONFIRMED)
  locationText String?
  notes        String?           @db.Text
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  lead Lead @relation(fields: [leadId], references: [id])

  @@index([companyId, scheduledAt])
  @@index([companyId, leadId])
  @@map("appointments")
}

// Recurring weekly working window (owner availability). Minutes are measured
// from local midnight; weekday is 0=Sunday..6=Saturday in PR local time.
model AvailabilityWindow {
  id          String   @id @default(uuid())
  companyId   String
  weekday     Int
  startMinute Int
  endMinute   Int
  createdAt   DateTime @default(now())

  @@index([companyId])
  @@map("availability_windows")
}

// One-off block of time the owner is unavailable (vacation, other job, etc).
model AvailabilityBlock {
  id        String   @id @default(uuid())
  companyId String
  startAt   DateTime
  endAt     DateTime
  reason    String?
  createdAt DateTime @default(now())

  @@index([companyId, startAt])
  @@map("availability_blocks")
}

// Singleton per company: default visit length and the slot granularity shown
// in the scheduler.
model SchedulingSettings {
  id                  String   @id @default(uuid())
  companyId           String   @unique
  defaultVisitMinutes Int      @default(60)
  slotMinutes         Int      @default(30)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("scheduling_settings")
}
