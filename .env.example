# ── Core ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3333
APP_URL=http://localhost:3333
CORS_ORIGINS=http://localhost:4200

# ── Database (matches docker-compose.yml) ──────────────────────────
DATABASE_URL=mysql://verza:verza_dev@localhost:3307/verza_os

# ── Tenant bootstrap (single-tenant MVP; tenant-aware schema) ──────
DEFAULT_COMPANY_ID=c0a80121-7ac0-4e1c-9b25-000000000001
DEFAULT_COMPANY_SLUG=verza-garden

# ── Seed-only (owner account) ───────────────────────────────────────
SEED_OWNER_EMAIL=owner@verzagarden.com
SEED_OWNER_NAME=Angel Agramonte

# ── Storage (Day 6 uses this; validated now so boot fails early) ────
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./uploads

# ── AI (Day 3+; optional until enabled) ─────────────────────────────
AI_ENABLED=false
AI_PROVIDER_BASE_URL=
AI_PROVIDER_API_KEY=
AI_MODEL=

# ── Rate limiting ────────────────────────────────────────────────────
RATE_LIMIT_PUBLIC_RPM=30
