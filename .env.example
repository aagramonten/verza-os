# ── Core ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3333
APP_URL=http://localhost:3333
CORS_ORIGINS=http://localhost:4200

# ── Database (matches docker-compose.yml) ──────────────────────────
DATABASE_URL=mysql://verza:verza_dev@localhost:3307/verza_os

# ── Tenant bootstrap (single-tenant MVP; tenant-aware schema) ──────
DEFAULT_COMPANY_ID=c0a80121-7ac0-4e1c-9b25-000000000001
DEFAULT_COMPANY_SLUG=verza-garden

# ── Seed-only (owner account) ───────────────────────────────────────
SEED_OWNER_EMAIL=owner@verzagarden.com
SEED_OWNER_NAME=Angel Agramonte
SEED_OWNER_PASSWORD=

# ── Admin authentication ───────────────────────────────────────────
# Replace with a long random value outside local development.
AUTH_JWT_SECRET=change-me-change-me-change-me-change-me
AUTH_ACCESS_TTL_MIN=15
AUTH_REFRESH_TTL_DAYS=30
AUTH_LOGIN_RATE_LIMIT_PER_MIN=10

# ── Storage (Day 6 uses this; validated now so boot fails early) ────
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./uploads

# ── AI (Day 3+; optional until enabled) ─────────────────────────────
AI_ENABLED=false
AI_PROVIDER_BASE_URL=
AI_PROVIDER_API_KEY=
AI_MODEL=

# ── Rate limiting ────────────────────────────────────────────────────
RATE_LIMIT_PUBLIC_RPM=30

# Resume token lifetime (public chat)
RESUME_TOKEN_TTL_DAYS=30

# Customer portal passwordless authentication
CUSTOMER_MAGIC_LINK_TTL_MIN=15
CUSTOMER_SESSION_TTL_DAYS=30
CUSTOMER_AUTH_RATE_LIMIT_PER_MIN=5
CUSTOMER_MAGIC_LINK_PROVIDER=noop
CUSTOMER_PORTAL_URL=http://localhost:4200
CUSTOMER_EMAIL_FROM=
RESEND_API_KEY=
TRUST_PROXY_HOPS=1
